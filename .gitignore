# Never commit secrets or local key stores
.env
*.env
.fds_key
**/.fds_key
config.json
**/config.json
.financial-datasets/
secrets*
*api*key*
*.key

# Python
__pycache__/
*.pyc
.venv/
venv/

# OS
.DS_Store

# Skill-creator eval workspace (local test runs)
*-workspace/

# Local-only docs (kept on disk, not published).
# The OpenAPI spec (docs/fds-openapi.json) stays tracked as the source of truth;
# only the internal design notes and the maintenance generator are ignored.
docs/*-design.md
docs/gen_endpoints.py
